<Window x:Class="KKTD_V3.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KKTD_V3.ViewModels"
        xmlns:views="clr-namespace:KKTD_V3.Views"
        mc:Ignorable="d"
        Title="KKTD V3 — Kamera-Kontroll-Teil-Detektion"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LiveViewModel}">
            <views:LiveView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TeachViewModel}">
            <views:TeachView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
            <views:CatalogView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top" Background="#1F2937" Padding="12,8">
            <DockPanel>
                <TextBlock Text="KKTD V3"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button Content="Live"
                            Command="{Binding ShowLiveCommand}"
                            Margin="4,0" Padding="14,6" />
                    <Button Content="Teach-In"
                            Command="{Binding ShowTeachCommand}"
                            Margin="4,0" Padding="14,6" />
                    <Button Content="Katalog"
                            Command="{Binding ShowCatalogCommand}"
                            Margin="4,0" Padding="14,6" />
                    <ToggleButton Content="Werker anwesend"
                                  IsChecked="{Binding WorkerPresent, Mode=TwoWay}"
                                  Margin="16,0,4,0" Padding="14,6" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#111827" Padding="12,4">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#E5E7EB"
                           DockPanel.Dock="Left" />
                <TextBlock Text="{Binding ModeText}"
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Content="{Binding CurrentView}" Margin="0" />
    </DockPanel>
</Window>
